{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KingdomOS",
  "version": "0.2.0",
  "identifier": "com.jonat.kingdomos",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5876",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "KingdomOS",
        "width": 1280,
        "height": 720,
        "minWidth": 640,
        "minHeight": 360,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "tooltip": "KingdomOS — your kingdom lives here"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/jonat/kingdomos/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "REPLACE_WITH_PUBLIC_KEY_FROM_TAURI_SIGNER_GENERATE"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png"
    ],
    "shortDescription": "An ambient 16-bit fantasy kingdom that lives on your desktop.",
    "longDescription": "KingdomOS is an ambient desktop app that generates a living SNES-style fantasy kingdom. NPCs marry, age, and die. Seasons turn. Usurpers challenge the throne. The kingdom reacts to your real git commits, CPU load, and system idle time — or runs entirely on its own. Leave it open while you work and come back to a world that moved on without you.",
    "category": "Game",
    "copyright": "Copyright © 2025",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "nsis": {
        "displayLanguageSelector": false,
        "languages": ["English"],
        "installerIcon": "icons/icon.png",
        "headerImage": null,
        "sidebarImage": null
      }
    }
  }
}
