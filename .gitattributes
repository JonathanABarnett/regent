# Normalize line endings: store as LF in the repo, check out native.
# Kills the "LF will be replaced by CRLF" warning on every Windows commit.
* text=auto eol=lf

# Treat known binaries as binary so git never tries to normalize them.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.mp3   binary
*.wav   binary
*.webm  binary
*.ase   binary
*.aseprite binary
